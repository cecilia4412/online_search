# 自动规范化行尾
* text=auto

# Python 文件使用 LF
*.py text eol=lf

# Shell 脚本使用 LF
*.sh text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 配置文件使用 LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.env* text eol=lf

# Markdown 文件使用 LF
*.md text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
